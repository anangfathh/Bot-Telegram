# Docker Environment Variables Template
# Copy this file to .env (or .env.docker locally) and fill in your actual values

# ========================================
# TELEGRAM CONFIGURATION
# ========================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1002920056294
TELEGRAM_CHANNEL_USERNAME=@cobaanjem

# ========================================
# DRIVER CONFIGURATION
# ========================================
DRIVER_CONTACT_USERNAME=@youradmin,@driveradmin2
DRIVER_GROUP_ID=-1001234567890
DRIVER_GROUP_INVITE_LINK=https://t.me/+xxxxxxxxxxxxx
DRIVER_DEFAULT_ACTIVE_DAYS=30
DRIVER_ADMIN_IDS=123456789,987654321
PRICE_BASE_FARE=7000
PRICE_STEP_FARE=1500
PRICE_DISTANCE_STEP_METERS=500
PRICE_RAIN_SURCHARGE=5000
PRICE_NIGHT_SURCHARGE=5000

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-this-db-password
DB_NAME=mager_bot
DB_CONNECTION_LIMIT=10

# ========================================
# ADMIN DASHBOARD AUTH
# ========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_SESSION_TTL_HOURS=12

# ========================================
# PORTS
# ========================================
API_PORT=3001
FRONTEND_PORT=8080

# ========================================
# GOOGLE SHEETS INTEGRATION (OPTIONAL)
# ========================================
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEETS_ENABLED=false

# ========================================
# PRODUCTION IMAGE SETTINGS (OPTIONAL)
# ========================================
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_BOT=anangfathh/bot-telegram
DOCKER_IMAGE_FRONTEND=anangfathh/bot-telegram-frontend
IMAGE_TAG=latest
